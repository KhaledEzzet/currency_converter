{
  "manifest_version": 3,
  "name": "Currency Converter – Live Rates, Charts & Multi-Currency Tracking",
  "short_name": "Currency Converter",
  "description": "Real-time currency converter chrome extension with live exchange rates, historical currency charts, and forex rate tracker.",
  "version": "1.0.27",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Currency Converter",
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "extension/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "extension/content_script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/Icon-192.png",
    "32": "icons/Icon-192.png",
    "48": "icons/Icon-192.png",
    "128": "icons/Icon-512.png"
  },
  "host_permissions": [
    "https://api.frankfurter.app/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}
